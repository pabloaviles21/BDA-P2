PREFIX ex: <https://example.org/bda/nyc-mobility-safety/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

# Goal: compare contributing-factor profiles between weekends and weekdays.
#
# Why this query is graph-based:
# Calendar semantics are attached to Day nodes with ex:isWeekend, while
# contributing factors are reached through FactorCount nodes:
#   Day -> FactorCount -> ContributingFactor
# SPARQL can combine these two descriptions of the same Day and compare factor
# behaviour across calendar categories.
#
# How it works:
# - Computes the number of weekend and weekday days directly from the KG.
# - Aggregates factor occurrences separately for weekends and weekdays.
# - Normalizes by the number of days in each group to avoid comparing raw totals
#   from groups of different size.
# - Orders factors by the largest weekend-weekday difference.
#
# Main observation from the generated output:
# Most frequent factors, such as DRIVER INATTENTION/DISTRACTION and FAILURE TO
# YIELD RIGHT-OF-WAY, have higher average daily occurrence on weekdays.
# ALCOHOL INVOLVEMENT and PAVEMENT SLIPPERY are examples where the weekend
# average is relatively higher.

SELECT ?factorLabel
       ?weekendOccurrences
       ?weekdayOccurrences
       ?weekendDays
       ?weekdayDays
       (?weekendOccurrences / ?weekendDays AS ?avgWeekendOccurrencesPerCalendarDay)
       (?weekdayOccurrences / ?weekdayDays AS ?avgWeekdayOccurrencesPerCalendarDay)
       ((?weekendOccurrences / ?weekendDays) - (?weekdayOccurrences / ?weekdayDays) AS ?weekendMinusWeekdayAvg)
WHERE {
  {
    SELECT (SUM(IF(xsd:boolean(?isWeekend), 1, 0)) AS ?weekendDays)
           (SUM(IF(xsd:boolean(?isWeekend), 0, 1)) AS ?weekdayDays)
    WHERE {
      ?day ex:isWeekend ?isWeekend .
    }
  }

  {
    SELECT ?factorLabel
           (SUM(IF(xsd:boolean(?isWeekend), xsd:integer(?occurrences), 0)) AS ?weekendOccurrences)
           (SUM(IF(xsd:boolean(?isWeekend), 0, xsd:integer(?occurrences))) AS ?weekdayOccurrences)
    WHERE {
      ?day ex:isWeekend ?isWeekend ;
           ex:hasFactorCount ?factorCount .

      ?factorCount ex:aboutFactor ?factor ;
                   ex:occurrences ?occurrences .

      ?factor rdfs:label ?factorLabel .
    }
    GROUP BY ?factorLabel
  }
}
ORDER BY DESC(ABS((?weekendOccurrences / ?weekendDays) - (?weekdayOccurrences / ?weekdayDays)))
LIMIT 20
