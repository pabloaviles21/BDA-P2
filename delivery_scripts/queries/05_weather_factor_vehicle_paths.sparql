PREFIX ex: <https://example.org/bda/nyc-mobility-safety/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

# Goal: show concrete graph paths connecting adverse weather, contributing
# factors and vehicle types on the same day.
#
# Why this query is graph-based:
# This query is mainly explanatory. It returns explicit KG paths where the same
# Day node connects three semantic areas:
#   Day -> WeatherObservation
#   Day -> FactorCount -> ContributingFactor
#   Day -> VehicleTypeCount -> VehicleType
# The result illustrates that the KG is not only storing a flat table, but
# connecting reusable entities through meaningful relations.
#
# How it works:
# - Keeps rainy days with precipitation > 0.5.
# - Keeps relevant factors with at least 20 occurrences on that day.
# - Keeps relevant vehicle types with at least 30 occurrences on that day.
#
# Main observation from the generated output:
# The snow/rain event on 2016-01-23 is clearly visible: PAVEMENT SLIPPERY is
# highly represented together with passenger vehicles and sport utility/station
# wagons. Another strong rainy-day pattern appears on 2016-11-29 with DRIVER
# INATTENTION/DISTRACTION and FOLLOWING TOO CLOSELY.

SELECT ?date ?avgTemperature ?precipitation ?factorLabel ?factorOccurrences
       ?vehicleTypeLabel ?vehicleOccurrences
WHERE {
  ?day ex:eventDate ?date ;
       ex:hasWeatherObservation ?weather ;
       ex:hasFactorCount ?factorCount ;
       ex:hasVehicleTypeCount ?vehicleCount .

  ?weather ex:averageTemperature ?avgTemperature ;
           ex:precipitation ?precipitation .

  ?factorCount ex:aboutFactor ?factor ;
               ex:occurrences ?factorOccurrences .

  ?vehicleCount ex:aboutVehicleType ?vehicleType ;
                ex:occurrences ?vehicleOccurrences .

  ?factor rdfs:label ?factorLabel .
  ?vehicleType rdfs:label ?vehicleTypeLabel .

  FILTER(xsd:double(?precipitation) > 0.5)
  FILTER(xsd:integer(?factorOccurrences) >= 20)
  FILTER(xsd:integer(?vehicleOccurrences) >= 30)
}
ORDER BY DESC(xsd:double(?precipitation)) DESC(xsd:integer(?factorOccurrences))
LIMIT 20
