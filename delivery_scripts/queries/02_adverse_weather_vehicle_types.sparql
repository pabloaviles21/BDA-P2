PREFIX ex: <https://example.org/bda/nyc-mobility-safety/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

# Goal: rank vehicle types that appear most often on days with adverse weather.
#
# Why this query is graph-based:
# Weather and vehicle types come from different parts of the graph. SPARQL
# connects them through the shared Day node:
#   Day -> WeatherObservation
#   Day -> VehicleTypeCount -> VehicleType
# This is a natural graph pattern because weather is not stored in the same
# source as vehicle involvement.
#
# How it works:
# - Defines adverse weather as precipitation > 0.20, snowfall > 0, or snow depth > 0.
# - Finds the vehicle-type count nodes attached to those days.
# - Aggregates occurrences per vehicle type.
#
# Main observation from the generated output:
# Passenger vehicles are by far the most frequent vehicle type on adverse
# weather days, followed by sport utility/station wagon. Taxis, pick-up trucks,
# vans and bicycles also appear, but with much smaller totals.

SELECT ?vehicleTypeLabel
       (COUNT(DISTINCT ?day) AS ?adverseWeatherDays)
       (SUM(xsd:integer(?vehicleOccurrences)) AS ?totalVehicleOccurrences)
       (AVG(xsd:double(?precipitation)) AS ?avgPrecipitation)
       (AVG(xsd:double(?snowFall)) AS ?avgSnowFall)
       (AVG(xsd:double(?snowDepth)) AS ?avgSnowDepth)
WHERE {
  ?day ex:hasWeatherObservation ?weather ;
       ex:hasVehicleTypeCount ?vehicleCount .

  ?weather ex:precipitation ?precipitation ;
           ex:snowFall ?snowFall ;
           ex:snowDepth ?snowDepth .

  ?vehicleCount ex:aboutVehicleType ?vehicleType ;
                ex:occurrences ?vehicleOccurrences .

  ?vehicleType rdfs:label ?vehicleTypeLabel .

  FILTER(
    xsd:double(?precipitation) > 0.20 ||
    xsd:double(?snowFall) > 0.0 ||
    xsd:double(?snowDepth) > 0.0
  )
}
GROUP BY ?vehicleTypeLabel
ORDER BY DESC(?totalVehicleOccurrences)
LIMIT 15
