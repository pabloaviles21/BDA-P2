PREFIX ex: <https://example.org/bda/nyc-mobility-safety/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

# Goal: compare borough collision levels on days with high estimated Uber
# mobility.
#
# Why this query is graph-based:
# Uber mobility is city-level and borough safety is borough-level, so they
# should not be directly joined spatially. The KG connects both through Day:
#   Day -> MobilityObservation
#   Day -> SafetyObservation -> Borough
# This lets us analyse borough safety profiles under high city-level mobility
# without inventing borough-level Uber data.
#
# How it works:
# - Computes the average estimated dispatched trips across all mobility days.
# - Keeps days above that mobility threshold.
# - Aggregates borough collision observations on those days.
#
# Main observation from the generated output:
# On high-mobility days, Brooklyn has the highest average collisions per day,
# followed by Queens and Manhattan. Staten Island remains much lower, which is
# consistent with its smaller traffic volume and accident counts.

SELECT ?boroughLabel
       (COUNT(DISTINCT ?day) AS ?highMobilityDays)
       (AVG(xsd:double(?estimatedTrips)) AS ?avgEstimatedTrips)
       (SUM(xsd:integer(?collisions)) AS ?totalCollisions)
       (AVG(xsd:integer(?collisions)) AS ?avgCollisionsPerDay)
WHERE {
  {
    SELECT (AVG(xsd:double(?allTrips)) AS ?avgTripsThreshold)
    WHERE {
      ?anyDay ex:hasMobilityObservation ?anyMobility .
      ?anyMobility ex:estimatedDispatchedTrips ?allTrips .
    }
  }

  ?day ex:hasMobilityObservation ?mobility ;
       ex:hasSafetyObservation ?safety .

  ?mobility ex:estimatedDispatchedTrips ?estimatedTrips .
  ?safety ex:observedInBorough ?borough ;
          ex:collisions ?collisions .

  ?borough rdfs:label ?boroughLabel .

  FILTER(?borough != <https://example.org/bda/nyc-mobility-safety/borough/unknown>)
  FILTER(xsd:double(?estimatedTrips) > ?avgTripsThreshold)
}
GROUP BY ?boroughLabel
ORDER BY DESC(?avgCollisionsPerDay)
LIMIT 10
