PREFIX ex: <https://example.org/bda/nyc-mobility-safety/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

# Goal: identify which contributing factors are most associated with
# borough-days where collision counts are high.
#
# Why this query is graph-based:
# The result is obtained by joining two semantic paths through the same Day:
#   Day -> SafetyObservation -> Borough
#   Day -> FactorCount -> ContributingFactor
# This lets us ask which factors co-occur with high-risk borough/day contexts
# without flattening the KG into a single accident-weather-mobility table.
#
# How it works:
# - Keeps borough safety observations with at least 120 collisions.
# - Excludes UNKNOWN boroughs.
# - Aggregates factor occurrences for those high-collision day contexts.
# - Keeps factors appearing in at least 5 high-collision days.
#
# Main observation from the generated output:
# Brooklyn dominates the high-collision contexts, especially for
# DRIVER INATTENTION/DISTRACTION, FAILURE TO YIELD RIGHT-OF-WAY and
# FATIGUED/DROWSY. Queens and Manhattan show the same leading factors but
# with lower totals.

SELECT ?boroughLabel ?factorLabel
       (COUNT(DISTINCT ?day) AS ?highCollisionDays)
       (SUM(xsd:integer(?collisions)) AS ?totalBoroughCollisions)
       (SUM(xsd:integer(?factorOccurrences)) AS ?totalFactorOccurrences)
WHERE {
  ?day ex:hasSafetyObservation ?safety ;
       ex:hasFactorCount ?factorCount .

  ?safety ex:observedInBorough ?borough ;
          ex:collisions ?collisions .

  ?factorCount ex:aboutFactor ?factor ;
               ex:occurrences ?factorOccurrences .

  ?borough rdfs:label ?boroughLabel .
  ?factor rdfs:label ?factorLabel .

  FILTER(?borough != <https://example.org/bda/nyc-mobility-safety/borough/unknown>)
  FILTER(xsd:integer(?collisions) >= 120)
}
GROUP BY ?boroughLabel ?factorLabel
HAVING(COUNT(DISTINCT ?day) >= 5)
ORDER BY DESC(?totalFactorOccurrences) DESC(?totalBoroughCollisions)
LIMIT 15
